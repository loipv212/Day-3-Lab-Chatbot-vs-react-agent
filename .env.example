# ============================================================
# 9ROUTER (local gateway, OpenAI-compatible) - PROVIDER CHÍNH
# Proxy chạy local tại localhost:20128. Cài & chạy 9router trước.
# Có thể dán nhiều key, phân tách bằng dấu phẩy để xoay vòng.
# ============================================================
ROUTER_API_KEYS=sk-key1,sk-key2
ROUTER_BASE_URL=http://localhost:20128/v1

# ============================================================
# MiMo (Xiaomi) - provider phụ
# ============================================================
MIMO_API_KEYS=
MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1

# ============================================================
# GEMINI (provider phụ)
# Key chuẩn dạng AIza... lấy ở https://aistudio.google.com/apikey
# ============================================================
GEMINI_API_KEYS=
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
# OPENAI (provider phụ)
# ============================================================
OPENAI_API_KEYS=
OPENAI_API_KEY=your_openai_api_key_here

# ============================================================
# LOCAL LLM (GGUF via llama-cpp)
# ============================================================
LOCAL_MODEL_PATH=./models/Phi-3-mini-4k-instruct-q4.gguf

# ============================================================
# LAB CONFIG
# Options: router | mimo | google | openai | local
# ============================================================
DEFAULT_PROVIDER=router
DEFAULT_MODEL=cx/gpt-5.5
LOG_LEVEL=INFO
